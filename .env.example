# ================================================================
# Distributed Sync System — Environment Configuration
# ================================================================
# Salin file ini menjadi .env dan sesuaikan nilainya.
# Saat berjalan di Docker, host = nama service di docker-compose.
# Saat berjalan lokal, host = localhost.
# ================================================================

# --- LOCK CLUSTER ---
# Format: node_id:host:port,...
# Saat Docker: host = nama container (lock_node_1, dst)
# Saat lokal : host = localhost
LOCK_CLUSTER_NODES=lock_1:lock_node_1:8001,lock_2:lock_node_2:8002,lock_3:lock_node_3:8003

# --- QUEUE CLUSTER ---
QUEUE_CLUSTER_NODES=queue_1:queue_node_1:8011,queue_2:queue_node_2:8012,queue_3:queue_node_3:8013

# --- CACHE CLUSTER ---
CACHE_CLUSTER_NODES=cache_1:cache_node_1:8021,cache_2:cache_node_2:8022,cache_3:cache_node_3:8023

# --- CLUSTER_NODES GABUNGAN (backward compatible untuk pytest) ---
CLUSTER_NODES=node_1:localhost:8001,node_2:localhost:8002,node_3:localhost:8003

# --- REDIS ---
# Gunakan 'redis' (nama service) saat di Docker
# Gunakan 'localhost' saat pengujian lokal
REDIS_HOST=redis
REDIS_PORT=6379
