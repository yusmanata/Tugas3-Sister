# ===================================================
# .gitignore — Distributed Sync System
# ===================================================

# ───────────────────────────────────────
# Python
# ───────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.so

# Virtual environment
venv/
env/
.venv/
.env_venv/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# ───────────────────────────────────────
# Testing & Coverage
# ───────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.coveragerc
test_output.log
*.log

# ───────────────────────────────────────
# Data & Logs (generated at runtime)
# ───────────────────────────────────────
data/queue_logs/
data/audit_logs/
data/benchmark_results.json

# ───────────────────────────────────────
# Environment & Secrets
# ───────────────────────────────────────
# File .env aktif TIDAK di-push (berisi konfigurasi sensitif)
# Gunakan .env.example sebagai template
.env

# ───────────────────────────────────────
# Docker
# ───────────────────────────────────────
# Volume data Docker (jika mounted secara lokal)
docker-data/
redis-data/

# ───────────────────────────────────────
# IDE & Editor
# ───────────────────────────────────────
# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# ───────────────────────────────────────
# OS Files
# ───────────────────────────────────────
# Windows
Thumbs.db
desktop.ini
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~

# ───────────────────────────────────────
# Locust & Benchmark Outputs
# ───────────────────────────────────────
locust_report/
locust_stats*.csv
*.html

!.env.example
!data/.gitkeep


